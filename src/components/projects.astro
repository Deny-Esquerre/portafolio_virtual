---
import { Image } from "astro:assets";
import ogImage from "../../public/og.image.png";
import landingRizor from "../../public/landing_rizor.png";
import sistemaRizor from "../../public/sistema_rizor.png";
import landingSaldarriaga from "../../public/landing_transportes_saldarriaga.png";
import pauBoutique from "../../public/pau_boutique.png";
import landingSistemaTesis from "../../public/landing_sistema.png";

interface Project {
  title: string;
  description?: string;
  image: ImageMetadata;
  link: string;
  preview: string;
  status: string;
}

const projects: Project[] = [
  {
    title: "Rizo EIRL – Landing ERP",
    description: "Landing page diseñada específicamente para la presentación y venta de un sistema ERP empresarial.",
    image: landingRizor as ImageMetadata,
    link: "https://landingpage-rizoeirl.vercel.app",
    preview: "https://landingpage-rizoeirl.vercel.app",
    status: "Desplegado",
  },
  {
    title: "Rizor EIRL – ERP Sistema",
    description: "Plataforma ERP completa desplegada para la gestión integral de procesos de la empresa Rizo EIRL.",
    image: sistemaRizor as ImageMetadata,
    link: "https://rizor-e-i-r-l.vercel.app",
    preview: "https://rizor-e-i-r-l.vercel.app",
    status: "Desplegado",
  },
  {
    title: "Transportes Saldarriaga S.A.C. – Landing Page Corporativa",
    description: "Landing page corporativa para empresa de extracción y transporte de crudo. Diseño responsive que refuerza profesionalismo y eficiencia en el sector energético.",
    image: landingSaldarriaga as ImageMetadata,
    link: "https://transportes-saldarriaga.vercel.app/",
    preview: "https://transportes-saldarriaga.vercel.app/",
    status: "Desplegado",
  },
  {
    title: "Pau Boutique",
    description: "Plataforma e-commerce para una boutique de moda ubicada en la ciudad de Talara.",
    image: pauBoutique as ImageMetadata,
    link: "https://pau-boutique.vercel.app",
    preview: "https://pau-boutique.vercel.app",
    status: "Desplegado",
  },
  {
    title: "Paita Capital",
    description: "Aplicación dedicada a la gestión o información relevante de la zona de Paita.",
    image: ogImage as ImageMetadata,
    link: "#",
    preview: "#",
    status: "Desplegado",
  },
  {
    title: "Sistema Adaptativo Educativo – Landing Page",
    description: "Landing page informativa enfocada en innovación pedagógica y tecnología educativa.",
    image: landingSistemaTesis as ImageMetadata,
    link: "https://landing-sistema-tesis.vercel.app",
    preview: "https://landing-sistema-tesis.vercel.app",
    status: "Desplegado",
  },
  {
    title: "I.E. Ann Goulden – Landing Page Institucional",
    description: "Diseño responsive y optimización para presencia digital educativa, con un enfoque netamente informativo.",
    image: ogImage as ImageMetadata,
    link: "#",
    preview: "#",
    status: "Desplegado",
  },
  {
    title: "Sistema de Gestión Académica – I.E. Ann Goulden",
    description: "Sistema web administrativo con módulos de usuarios, control de alumnos, gestión de notas y panel administrativo.",
    image: ogImage as ImageMetadata,
    link: "#",
    preview: "#",
    status: "Desplegado",
  },
  {
    title: "Sistema Adaptativo Educativo – Plataforma Web",
    description: "Sistema web orientado al aprendizaje inteligente con panel administrativo y arquitectura para integración de IA.",
    image: ogImage as ImageMetadata,
    link: "#",
    preview: "#",
    status: "Desplegado",
  },
  {
    title: "Invernadero Automatizado con Arduino",
    description: "Sistema de automatización agrícola con monitoreo en tiempo real de temperatura, humedad y riego mediante sensores inteligentes.",
    image: ogImage as ImageMetadata,
    link: "#",
    preview: "#",
    status: "Completado",
  },
  {
    title: "Clasificador de Lesiones Cutáneas (ML)",
    description: "Modelo en Python con Machine Learning para análisis y clasificación de imágenes de lesiones cutáneas en cuatro categorías.",
    image: ogImage as ImageMetadata,
    link: "#",
    preview: "#",
    status: "Completado",
  },
];
---

<section
  id="projects"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">Mi trabajo</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Proyectos</h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        projects.map((project) => (
          <div class="group">
            <div class="rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 mb-4">
              <Image
                src={project.image}
                alt={project.title}
                class="w-full h-48 md:h-72 object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="px-3">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-grow">
                  <h4 class="text-2xl font-semibold leading-tight mb-1">{project.title}</h4>
                  <span class="py-1 text-xs uppercase tracking-wider text-[var(--sec)] font-medium">
                    {project.status}
                  </span>
                  <p class="mt-2 text-[var(--white-icon)] text-sm line-clamp-3">
                    {project.description}
                  </p>
                </div>
                <div class="flex gap-2 flex-shrink-0 mt-1">
                  {project.link !== "#" && (
                    <a
                      target="_blank"
                      href={project.link}
                      aria-label="GitHub/Code"
                      class="size-11 flex justify-center items-center text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-2 rounded-xl bg-[#1414149c] hover:bg-[var(--white-icon-tr)]"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
                        <path d="M24 12L18.3431 17.6569L16.9289 16.2426L21.1716 12L16.9289 7.75736L18.3431 6.34315L24 12ZM2.82843 12L7.07107 16.2426L5.65685 17.6569L0 12L5.65685 6.34315L7.07107 7.75736L2.82843 12ZM9.78845 21H7.66009L14.2116 3H16.3399L9.78845 21Z" />
                      </svg>
                    </a>
                  )}
                  {project.preview !== "#" && (
                    <a
                      target="_blank"
                      href={project.preview}
                      aria-label="Previsualización"
                      class="size-11 flex justify-center items-center text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-2 rounded-xl bg-[#1414149c] hover:bg-[var(--white-icon-tr)]"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
                        <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
    <a
      target="_blank"
      href="https://github.com/Deny-Esquerre"
      aria-label="GitHub"
      class="w-full flex items-center justify-center gap-2 mt-12 text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full bg-[#1414149c] hover:bg-[var(--white-icon-tr)] hover:scale-105"
    >
      <span class="md:text-lg text-md">Más proyectos en</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-6"
      >
        <path
          d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"
        ></path>
      </svg>
    </a>
  </div>
</section>
